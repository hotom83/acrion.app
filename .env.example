# ==============================================================================
# Acrion Platform — Environment Variables Example
# Copy this file to .env and fill in your actual credentials for local development.
# ==============================================================================

# --- Database (Prisma) ---
# Supports PostgreSQL, MySQL, SQLite, etc. (https://pris.ly/d/connection-strings)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# --- Authentication & Backend (Supabase) ---
VITE_SUPABASE_URL="https://abcdefghijklmnopqrst.supabase.co"
VITE_SUPABASE_ANON_KEY="ey_mock-anon-key"
SUPABASE_SERVICE_ROLE_KEY="ey_mock-service-role"

# --- Application Infrastructure ---
APP_URL="http://localhost:3000"
COOKIE_SECRET="a-sufficiently-long-secret-ideally-32-characters-or-more"
HONEYPOT_SECRET="super-duper-s3cret"

# --- Email Delivery (Resend) ---
RESEND_API_KEY="re_blAh_blaHBlaHblahBLAhBlAh"

# --- File Storage (Supabase Storage via S3 API) ---
# Used for temporary and secure PDF document processing
STORAGE_ACCESS_KEY_ID="ey_mock-access-key"
STORAGE_SECRET_ACCESS_KEY="ey_mock-secret-key"
STORAGE_REGION="us-east-1"
SUPABASE_PROJECT_ID="abcdefghijklmnopqrst"

# --- Payment Gateway (Stripe) ---
STRIPE_SECRET_KEY="sk_test_mockKey"
STRIPE_WEBHOOK_SECRET="whsec_mockWebhook"

# --- SEO, Monetization & Compliance (Acrion Specific) ---
ALLOW_INDEXING="false"
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
GOOGLE_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXX"
TERMLY_EMBED_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
